{
  "name": "studytrack",
  "version": "1.0.0",
  "description": "Study plan tracker",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build:sidecar": "pkg server.js --targets node18-macos-arm64 --output src-tauri/binaries/studytrack-server-aarch64-apple-darwin --public"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "chromadb": "^3.4.3",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "routes/**/*",
      "services/**/*",
      "version.json"
    ],
    "scripts": [
      "routes/*.js",
      "services/*.js"
    ]
  }
}
