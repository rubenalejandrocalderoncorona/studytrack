# StudyTrack environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Anthropic API key — required for AI exam generation and coding challenges.
# Get yours at https://console.anthropic.com/settings/keys
# To use a proxy, set this to your proxy key and override ANTHROPIC_BASE_URL below.
ANTHROPIC_API_KEY=your-api-key-here

# Optional: override the Anthropic API base URL (e.g. for a local proxy).
# NOTE: use host.docker.internal instead of localhost — the app runs inside Docker
# and localhost would point to the container, not your Mac.
# Example: ANTHROPIC_BASE_URL=http://host.docker.internal:6655
# ANTHROPIC_BASE_URL=
