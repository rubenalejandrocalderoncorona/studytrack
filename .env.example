# StudyTrack environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Anthropic API key — required for AI exam generation and coding challenges.
# Get yours at https://console.anthropic.com/settings/keys
# To use a proxy, set this to your proxy key and override ANTHROPIC_BASE_URL below.
ANTHROPIC_API_KEY=your-api-key-here

# Optional: override the Anthropic API base URL (e.g. for a proxy or local mock)
# ANTHROPIC_BASE_URL=https://your-proxy.example.com
